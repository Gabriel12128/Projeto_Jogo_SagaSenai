;   param=value ; assign values to parameters

config_version=5

[application]

config/name="PureDrop"
run/main_scene="uid://clvw34jsho20w"
config/features=PackedStringArray("4.6", "C#", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

Fade="*uid://cr7psylyrwpqi"
GameOver="*uid://bwvx1o46dsp8i"

[display]

window/size/borderless=true
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[dotnet]

project/assembly_name="PureDrop"

[global_group]

player=""
enemy=""
coletavel=""
barra=""
projetil=""
no_global=""

[gui]

common/snap/snap_2d_transforms_to_pixel=false

